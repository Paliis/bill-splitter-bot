BOT_TOKEN=your_bot_token_here

# Локально (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./bot.db

# Прод (Render тощо): ОБОВ'ЯЗКОВО зовнішній PostgreSQL — інакше після деплою зникнуть учасники й витрати.
# Neon / PostgreSQL (async): у консолі Neon скопіюй URI і заміни префікс на postgresql+asyncpg
# Приклад: postgresql+asyncpg://USER:PASSWORD@HOST/neondb?ssl=require

# Опційно — посилання Mono (кнопка в /help і після завершення події)
# SUPPORT_MONO_URL=https://send.monobank.ua/...
# Опційно — фідбек розробнику (кнопка в /help), наприклад https://t.me/your_username
# SUPPORT_FEEDBACK_URL=https://t.me/...
